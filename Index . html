<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0"/>
  <title>Bewaji Olamide · Teaching Portfolio</title>
  <link href="https://fonts.googleapis.com/css2?family=Playfair+Display:ital,wght@0,400;0,700;1,400&family=DM+Sans:wght@300;400;500&display=swap" rel="stylesheet"/>
  <style>
    *, *::before, *::after { box-sizing: border-box; margin: 0; padding: 0; }

    :root {
      --ink: #1a1410;
      --cream: #f5f0e8;
      --warm: #e8dece;
      --gold: #b8860b;
      --rust: #8b3a1e;
      --sage: #5a6e52;
      --paper: #faf7f2;
    }

    html { scroll-behavior: smooth; }

    body {
      font-family: 'DM Sans', sans-serif;
      background: var(--paper);
      color: var(--ink);
      overflow-x: hidden;
    }

    /* ── NAV ── */
    nav {
      position: fixed; top: 0; left: 0; right: 0; z-index: 100;
      display: flex; justify-content: space-between; align-items: center;
      padding: 1.2rem 3rem;
      background: var(--paper);
      border-bottom: 1px solid var(--warm);
    }
    .nav-logo {
      font-family: 'Playfair Display', serif;
      font-size: 1.1rem; letter-spacing: .04em;
      color: var(--ink); text-decoration: none;
    }
    .nav-links { display: flex; gap: 2rem; list-style: none; }
    .nav-links a {
      text-decoration: none; color: var(--ink); font-size: .85rem;
      font-weight: 500; letter-spacing: .06em; text-transform: uppercase;
      opacity: .7; transition: opacity .2s;
    }
    .nav-links a:hover { opacity: 1; }

    /* ── HERO ── */
    #hero {
      min-height: 100vh;
      display: grid; grid-template-columns: 1fr 1fr;
      padding-top: 70px;
    }
    .hero-left {
      background: var(--ink);
      display: flex; flex-direction: column; justify-content: center;
      padding: 5rem 4rem; position: relative; overflow: hidden;
    }
    .hero-left::before {
      content: ''; position: absolute; inset: 0;
      background: repeating-linear-gradient(
        -45deg, transparent, transparent 40px,
        rgba(255,255,255,.02) 40px, rgba(255,255,255,.02) 41px
      );
    }
    .hero-eyebrow {
      font-size: .75rem; letter-spacing: .2em; text-transform: uppercase;
      color: var(--gold); margin-bottom: 1.5rem; font-weight: 500;
    }
    .hero-name {
      font-family: 'Playfair Display', serif;
      font-size: clamp(2.8rem, 5vw, 4.2rem);
      line-height: 1.1; color: var(--cream); margin-bottom: 1rem;
    }
    .hero-name em { color: var(--gold); font-style: italic; }
    .hero-subtitle {
      font-size: 1rem; color: rgba(245,240,232,.6);
      line-height: 1.7; max-width: 34ch; margin-bottom: 2.5rem;
    }
    .hero-cta {
      display: inline-flex; gap: 1rem; align-items: center;
      text-decoration: none; color: var(--cream);
      font-size: .85rem; letter-spacing: .1em; text-transform: uppercase;
      font-weight: 500; transition: gap .3s;
    }
    .hero-cta:hover { gap: 1.5rem; }
    .hero-cta span { width: 40px; height: 1px; background: var(--gold); display: inline-block; }

    .hero-right {
      background: var(--cream);
      display: flex; flex-direction: column; justify-content: flex-end;
      padding: 4rem 4rem 5rem; gap: 2rem;
    }
    .stat-block { display: flex; flex-direction: column; gap: .3rem; }
    .stat-number {
      font-family: 'Playfair Display', serif;
      font-size: 3.5rem; font-weight: 700; line-height: 1; color: var(--rust);
    }
    .stat-label {
      font-size: .8rem; letter-spacing: .12em; text-transform: uppercase;
      color: rgba(26,20,16,.5); font-weight: 500;
    }
    .stats-row { display: flex; gap: 3rem; }
    .hero-quote {
      font-family: 'Playfair Display', serif;
      font-style: italic; font-size: 1.25rem;
      line-height: 1.6; color: var(--ink);
      border-left: 3px solid var(--gold); padding-left: 1.5rem;
    }
    .hero-subjects { display: flex; flex-wrap: wrap; gap: .5rem; }
    .subject-tag {
      padding: .35rem .9rem; border: 1px solid rgba(26,20,16,.2);
      font-size: .75rem; letter-spacing: .08em; text-transform: uppercase;
      border-radius: 2px; color: rgba(26,20,16,.7);
    }

    /* ── SECTIONS ── */
    section { padding: 6rem 3rem; }
    @keyframes fadeUp {
      from { opacity: 0; transform: translateY(30px); }
      to   { opacity: 1; transform: translateY(0); }
    }
    .section-header {
      display: flex; align-items: baseline; gap: 1.5rem; margin-bottom: 4rem;
    }
    .section-num { font-family: 'Playfair Display', serif; font-size: .8rem; color: var(--gold); }
    .section-title {
      font-family: 'Playfair Display', serif;
      font-size: clamp(2rem, 3.5vw, 2.8rem); line-height: 1.15;
    }
    .section-line { flex: 1; height: 1px; background: var(--warm); }

    /* ── EXPERIENCE TIMELINE ── */
    #experience { background: var(--paper); }
    .timeline { display: flex; flex-direction: column; gap: 0; position: relative; }
    .timeline::before {
      content: ''; position: absolute; left: 11px; top: 8px; bottom: 8px;
      width: 2px; background: var(--warm);
    }
    .timeline-item {
      display: grid; grid-template-columns: 24px 1fr;
      gap: 2rem; padding-bottom: 3rem; position: relative;
    }
    .timeline-dot {
      width: 24px; height: 24px; border-radius: 50%;
      background: var(--paper); border: 2px solid var(--gold);
      flex-shrink: 0; margin-top: 4px; position: relative; z-index: 1;
    }
    .timeline-dot.active { background: var(--gold); }
    .timeline-content {
      background: var(--cream); padding: 1.8rem 2rem;
      border-radius: 6px; border-left: 3px solid transparent;
      transition: border-color .3s, transform .3s;
    }
    .timeline-content:hover { border-color: var(--gold); transform: translateX(4px); }
    .timeline-period {
      font-size: .72rem; letter-spacing: .15em; text-transform: uppercase;
      color: var(--gold); margin-bottom: .5rem; font-weight: 500;
    }
    .timeline-role {
      font-family: 'Playfair Display', serif;
      font-size: 1.2rem; margin-bottom: .3rem;
    }
    .timeline-org {
      font-size: .85rem; color: rgba(26,20,16,.5);
      margin-bottom: .9rem; font-weight: 500;
    }
    .timeline-desc {
      font-size: .9rem; line-height: 1.7; color: rgba(26,20,16,.75);
    }
    .timeline-tags { display: flex; flex-wrap: wrap; gap: .4rem; margin-top: 1rem; }
    .timeline-tag {
      font-size: .7rem; letter-spacing: .08em; text-transform: uppercase;
      padding: .2rem .6rem; border-radius: 2px;
      background: var(--warm); color: rgba(26,20,16,.6);
    }

    /* ── PHILOSOPHY ── */
    #philosophy { background: var(--cream); }
    .philosophy-grid {
      display: grid; grid-template-columns: 1fr 1fr; gap: 4rem; align-items: start;
    }
    .philosophy-text p {
      font-size: 1.05rem; line-height: 1.85;
      color: rgba(26,20,16,.8); margin-bottom: 1.2rem;
    }
    .philosophy-text p:first-child::first-letter {
      font-family: 'Playfair Display', serif;
      font-size: 3.5rem; font-weight: 700; float: left;
      line-height: .85; margin-right: .1em; color: var(--gold);
    }
    .values-list { display: flex; flex-direction: column; gap: 1.5rem; }
    .value-item {
      padding: 1.5rem; background: var(--paper);
      border-radius: 4px; border-left: 3px solid transparent;
      transition: border-color .3s, transform .3s;
    }
    .value-item:hover { border-color: var(--gold); transform: translateX(6px); }
    .value-item h4 { font-family: 'Playfair Display', serif; font-size: 1.1rem; margin-bottom: .4rem; }
    .value-item p { font-size: .9rem; line-height: 1.6; color: rgba(26,20,16,.65); }

    /* ── TEACHING WORK ── */
    #lessons { background: var(--paper); }
    .lessons-grid { display: grid; grid-template-columns: repeat(3, 1fr); gap: 2rem; }
    .lesson-card {
      background: var(--cream); border-radius: 6px; overflow: hidden;
      transition: transform .3s, box-shadow .3s; cursor: default;
    }
    .lesson-card:hover { transform: translateY(-6px); box-shadow: 0 20px 40px rgba(26,20,16,.1); }
    .lesson-card-top { padding: 2rem 2rem 1.5rem; background: var(--ink); }
    .lesson-grade {
      font-size: .7rem; letter-spacing: .15em; text-transform: uppercase;
      color: var(--gold); margin-bottom: .7rem;
    }
    .lesson-title { font-family: 'Playfair Display', serif; font-size: 1.25rem; color: var(--cream); line-height: 1.3; }
    .lesson-body { padding: 1.5rem 2rem 2rem; }
    .lesson-desc { font-size: .9rem; line-height: 1.65; color: rgba(26,20,16,.75); margin-bottom: 1.2rem; }
    .lesson-meta { display: flex; gap: .6rem; flex-wrap: wrap; }
    .meta-chip {
      font-size: .72rem; letter-spacing: .08em; text-transform: uppercase;
      padding: .25rem .7rem; border-radius: 2px;
      background: var(--warm); color: rgba(26,20,16,.6);
    }

    /* ── TESTIMONIALS ── */
    #testimonials { background: var(--ink); }
    #testimonials .section-title { color: var(--cream); }
    #testimonials .section-num { color: var(--gold); }
    #testimonials .section-line { background: rgba(245,240,232,.15); }
    .testimonials-grid { display: grid; grid-template-columns: repeat(3, 1fr); gap: 2rem; }
    .testimonial-card {
      padding: 2.5rem; border: 1px solid rgba(245,240,232,.12);
      border-radius: 4px; transition: border-color .3s, background .3s;
    }
    .testimonial-card:hover { border-color: var(--gold); background: rgba(184,134,11,.04); }
    .testimonial-quote {
      font-family: 'Playfair Display', serif; font-style: italic;
      font-size: 1rem; line-height: 1.75; color: rgba(245,240,232,.85); margin-bottom: 1.5rem;
    }
    .testimonial-quote::before { content: '\201C'; font-size: 2rem; color: var(--gold); line-height: 0; vertical-align: -.4em; margin-right: .1em; }
    .testimonial-author { display: flex; flex-direction: column; gap: .2rem; }
    .author-name { font-size: .85rem; font-weight: 500; color: var(--cream); }
    .author-role { font-size: .75rem; letter-spacing: .08em; text-transform: uppercase; color: rgba(245,240,232,.4); }
    .achievement-banner {
      margin-top: 4rem; padding: 3rem;
      background: linear-gradient(135deg, var(--rust) 0%, #6b2a10 100%);
      border-radius: 6px; display: grid; grid-template-columns: repeat(4, 1fr);
      gap: 2rem; text-align: center;
    }
    .ach-item { display: flex; flex-direction: column; gap: .4rem; }
    .ach-num { font-family: 'Playfair Display', serif; font-size: 2.5rem; font-weight: 700; color: var(--cream); }
    .ach-label { font-size: .75rem; letter-spacing: .1em; text-transform: uppercase; color: rgba(245,240,232,.65); }

    /* ── FOOTER ── */
    footer {
      background: var(--warm); padding: 3rem;
      display: flex; justify-content: space-between; align-items: center;
    }
    .footer-left { font-family: 'Playfair Display', serif; font-size: 1.2rem; }
    .footer-contact { font-size: .85rem; color: rgba(26,20,16,.6); }

    /* ── REVEAL ── */
    .reveal { opacity: 1; transform: none; }
    .reveal.visible { opacity: 1; transform: none; }

    @media (max-width: 900px) {
      #hero { grid-template-columns: 1fr; }
      .hero-left { padding: 4rem 2rem; }
      .hero-right { padding: 3rem 2rem; }
      .philosophy-grid, .lessons-grid, .testimonials-grid { grid-template-columns: 1fr; }
      nav { padding: 1rem 1.5rem; }
      .nav-links { gap: 1.2rem; }
      .achievement-banner { grid-template-columns: 1fr 1fr; }
      footer { flex-direction: column; gap: 1rem; text-align: center; }
      section { padding: 4rem 1.5rem; }
    }
  </style>
</head>
